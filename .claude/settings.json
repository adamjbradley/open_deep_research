{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-worktree-advisor.py\"",
            "timeout": 10,
            "statusMessage": "Checking for sessions sharing this working tree…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-worktree-redirect.py\"",
            "timeout": 20,
            "statusMessage": "Checking branch switch against shared working tree…"
          }
        ]
      }
    ]
  }
}
