{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-cross-session-guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking for concurrent sessions…"
          }
        ]
      }
    ]
  }
}
