# --- LLM backend: Claude Code / Claude Agent SDK ---
# All LLM activity runs through the Claude Agent SDK (the `claude` CLI). When
# CLAUDE_USE_SUBSCRIPTION=true, usage bills against your logged-in Claude Pro/Max
# subscription. Requirements: the Claude Code CLI installed and logged in
# (`claude` on PATH), and a one-time opt-in to the Agent SDK monthly credit.
# IMPORTANT: leave ANTHROPIC_API_KEY EMPTY in subscription mode — if it is set,
# the SDK routes to pay-per-token API billing instead.
CLAUDE_USE_SUBSCRIPTION=true
# Max concurrent Claude Agent SDK sessions (subscription tiers throttle ~5-7).
CLAUDE_SDK_MAX_CONCURRENCY=4

# --- Optional alternate backends: Gemini CLI / Codex CLI (also login, not API) ---
# Pick the LLM backend PER ROLE via a provider prefix on each *_MODEL value, e.g.
#   RESEARCH_MODEL=gemini:2.5-pro   FINAL_REPORT_MODEL=codex:gpt-5
#   SUMMARIZATION_MODEL=claude:haiku
# No prefix = Claude (e.g. "opus"/"sonnet"/"haiku"). Pick the SEARCH backend with
# SEARCH_API=claude|gemini|codex|tavily|none.
# Requirements: install + log in to the CLI you use (`gemini` / `codex`). Leave the
# matching API keys EMPTY (GEMINI_API_KEY/GOOGLE_API_KEY, OPENAI_API_KEY) so the
# CLI uses your login/free-tier instead of paid API billing.
# Override the CLI binary/flags if your install differs:
# GEMINI_CLI_BIN=gemini            # standard Google gemini CLI (NOT `agy`/Antigravity --
#                                  # agy is an agentic CLI that writes artifacts instead of
#                                  # returning the structured envelope this graph parses).
# GEMINI_CLI_ARGS=                 # leave empty; `--dangerously-skip-permissions` is agy-only
#                                  # and the standard gemini CLI rejects it (exit 1).
# GEMINI_CLI_TRUST_WORKSPACE=true  # set by default in-code; the gemini CLI refuses headless
#                                  # runs in an "untrusted" dir otherwise (exit 55).
# CLI_BACKEND_TIMEOUT=600
#
# Gemini: run `gemini` once interactively and choose "Login with Google" so headless
#   `-p` mode has cached OAuth credentials (free tier). Without it, -p errors asking
#   for an auth method.
#   VERIFIED-WORKING model id for the standard gemini CLI: `gemini-2.5-flash`
#   (e.g. RESEARCHER_MODEL=gemini:gemini-2.5-flash). NB `gemini-2.0-flash` returns 404.
#
# Codex caveat: `codex exec` with --dangerously-bypass-approvals-and-sandbox is an
#   AGENTIC coding agent -- given a research prompt in the repo it will run repo commands
#   (e.g. `pytest`) instead of answering. Keep codex OUT of model roles until its sandbox
#   is restricted to read-only/no-exec. Defaults therefore use gemini, not codex.
#
# Codex notes (from a real install):
# - The standalone installer does NOT put codex on PATH. Point CODEX_CLI_BIN at the exe:
# CODEX_CLI_BIN=C:\Users\<you>\.codex\packages\standalone\current\bin\codex.exe
# - ChatGPT-account logins only allow your plan's model: 'gpt-5' and 'gpt-5-codex'
#   are rejected; the working model (e.g. 'gpt-5.5') is whatever your `codex`
#   config.toml `model = ...` is set to. By default this integration passes NO -m
#   so codex uses that config.toml model. Force one with CODEX_DEFAULT_MODEL or a
#   per-role prefix (RESEARCH_MODEL=codex:gpt-5.5).
# CODEX_DEFAULT_MODEL=
# CODEX_CLI_ARGS=--skip-git-repo-check
# - Codex tries a WebSocket transport first; if your network blocks WebSockets it
#   auto-falls-back to HTTPS (works, but adds a few seconds of retry latency per call).

# --- Model routing (model_routing.json) ---
# Per-role/per-step model + per-backend settings live in model_routing.json (presets:
# 'gemini' (default), 'claude'). Resolution: explicit env (SUPERVISOR_MODEL etc.) >
# RunnableConfig > file step_override > file preset role > code default. So these env
# vars still work as one-off overrides on top of the file.
# MODEL_ROUTING_FILE=./model_routing.json   # default: ./model_routing.json then bundled
# MODEL_ROUTING_PRESET=gemini               # flip the whole pipeline: gemini|claude

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Tavily is still used for web search (only the LLM backend changed).
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# --- Result persistence (local SQLite) ---
# Completed research runs are auto-stored in a local SQLite DB. Optionally override
# the file path (default: research_results.db in the working directory). Disable
# persistence via the PERSIST_RESULTS=false config field if desired.
# RESEARCH_DB_PATH=research_results.db

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false